{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and identity.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "rw", "fr"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post shared by a farmer in the community.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "content", "createdAt"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "A comment on a community post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorUid", "content", "createdAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session between a user and the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" }
      }
    },
    "Room": {
      "title": "Private Room",
      "description": "A private chat room for a group of users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creator": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "isPrivate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creator", "members", "createdAt"]
    }
  },
  "firestore": {
    "/settings/app": {
      "schema": "AppSettings",
      "description": "Global app configuration."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat sessions for a user."
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a specific chat session."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific post."
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Private chat rooms."
    }
  }
}